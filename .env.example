# Copy this file to .env (gitignored) and fill in real values.
# Never commit the real .env file to a public repository.
#
# If a value is left as PLACEHOLDER_NOT_CONFIGURED, the corresponding
# feature will be disabled at runtime (the app's Kotlin code checks for
# this string and shows a friendly error to the user).

# OAuth Web Client ID from Firebase Console > Authentication > Sign-in method > Google
GOOGLE_WEB_CLIENT_ID=PLACEHOLDER_NOT_CONFIGURED

# Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=PLACEHOLDER_NOT_CONFIGURED
